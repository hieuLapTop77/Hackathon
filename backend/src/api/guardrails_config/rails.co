# ── Định nghĩa các câu lệnh đầu vào của User (Static Triggers) ───────────────────

define user check input
  "check input"

define user check output
  "check output"

# ── Định nghĩa phản hồi của Bot ───────────────────────────────────────────────

define bot refuse request
  "BLOCKED: {$reason}"

define bot allow request
  "ALLOWED: {$text}"

define bot refuse output
  "BLOCKED: {$reason}"

define bot allow output
  "ALLOWED: {$text}"

# ── Luồng kiểm tra An toàn Đầu vào (Input Guardrails Flow) ──────────────────────

define flow check input safety
  user check input

  # 1. Chạy Custom Action để quét Regex và kiểm tra Độ dài ($query nhận từ Python context)
  $check_res = execute check_input_safety(query=$query)
  if $check_res.blocked
    $reason = $check_res.reason
    bot refuse request
    stop

  # 2. Gọi LLM của NVIDIA để đánh giá ngữ nghĩa (Semantic Self-check)
  $llm_allowed = execute self_check_input(query=$query)
  if not $llm_allowed
    $reason = "Phát hiện yêu cầu không an toàn hoặc ngoài phạm vi qua phân tích LLM."
    bot refuse request
    stop

  # 3. Chạy Custom Action quét và che giấu PII (Mã hóa Passport, SĐT, CCCD, Email...)
  $sanitized = execute redact_pii_input(query=$query)
  $text = $sanitized.result
  bot allow request

# ── Luồng kiểm tra An toàn Đầu ra (Output Guardrails Flow) ─────────────────────

define flow check output safety
  user check output

  # 1. Chạy Custom Action kiểm tra tính hợp lệ của giá trị kinh doanh ($message nhận từ Python context)
  $check_res = execute check_output_safety(response=$message)
  if $check_res.blocked
    $reason = $check_res.reason
    bot refuse output
    stop

  # 2. Gọi LLM của NVIDIA để đánh giá ngữ nghĩa phản hồi (Semantic Self-check)
  $llm_allowed = execute self_check_output(text=$message)
  if not $llm_allowed
    $reason = "Hệ thống phát hiện nội dung phản hồi của Bot không an toàn hoặc chứa lỗi dữ liệu qua phân tích LLM."
    bot refuse output
    stop

  # 3. Chạy Custom Action quét và làm sạch PII bị lọt vào output
  $sanitized = execute redact_pii_output(text=$message)
  $text = $sanitized.result
  bot allow output
